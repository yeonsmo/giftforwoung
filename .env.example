# ============================================================
# Insurance Ad Compliance - Environment Variables
# Copy this file to .env.local for local development.
# Set the same variables in Vercel Project Settings for production.
# Do NOT commit .env / .env.local. Never wrap a secret in NEXT_PUBLIC_.
#
# Only variables prefixed with NEXT_PUBLIC_ are sent to the browser.
# Everything else is server-only.
# ============================================================

# --- App (Step 1) ---
NODE_ENV=development
# Public: used for auth redirects and absolute URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (Step 1 / Step 2) ---
# URL and anon key are public by design; Row Level Security protects the data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role bypasses RLS. SERVER-ONLY. Used by the admin client and seed script.
SUPABASE_SERVICE_ROLE_KEY=

# --- Super Admin Seed (Step 2) ---
# Consumed only by scripts/seed-super-admin.ts. SERVER-ONLY.
# The Super Admin account exists only as this seed; it cannot be created via the UI.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# --- Encryption key for secrets stored in the DB (Step 4) ---
# AI API keys are stored ENCRYPTED in the database, not in env vars.
# This is the AES-256-GCM master key (32 random bytes, base64). SERVER-ONLY.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=

# --- Korean MOLEG / 법제처 API (Step 3) ---
# The 법제처 key is managed independently of the 91-day update counter.
# It may live here OR be moved to an encrypted DB column in Step 3.
# If kept here, it is SERVER-ONLY (never NEXT_PUBLIC_).
MOLEG_API_KEY=
MOLEG_API_BASE_URL=https://www.law.go.kr/DRF
# Update interval in days (spec: 91). Externalized, not hardcoded.
LEGISLATION_UPDATE_INTERVAL_DAYS=91

# --- AI providers (Step 4 / Step 5) ---
# Operational AI keys are stored ENCRYPTED in the DB via the settings UI, NOT here.
# Only non-secret defaults belong in env.
AI_DEFAULT_PROVIDER=gemini
# Minimum number of AI keys that activates multi-model debate orchestration.
AI_DEBATE_MIN_KEYS=2

# --- Generation / trend API (Step 6) ---
GENERATION_TREND_API_BASE_URL=
GENERATION_TREND_API_KEY=

# --- File upload / Cloud Storage (Step 4 video; avoids 4.5MB function limit) ---
# "supabase" uses Supabase Storage; "vercel_blob" uses Vercel Blob.
STORAGE_PROVIDER=supabase
# Vercel Blob token. SERVER-ONLY. Only needed if STORAGE_PROVIDER=vercel_blob.
BLOB_READ_WRITE_TOKEN=
SUPABASE_STORAGE_BUCKET=uploads
# Max upload size in MB. Externalized, not hardcoded.
MAX_UPLOAD_MB=512

# --- Webhooks / external API issuance (Step 8) ---
# HMAC secret for signing/verifying issued keys and inbound webhooks. SERVER-ONLY.
WEBHOOK_SIGNING_SECRET=

# --- Instagram auto-upload (Step 9 - FROZEN) ---
# This feature is fully coded but inactive. Leave the flag false and creds empty.
# Setting the flag true AND providing the creds is all that is needed to activate.
# Note: Instagram Graph API requires a Business/Creator account, a linked
# Facebook Page, and Meta app review before it can publish.
FEATURE_INSTAGRAM_ENABLED=false
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
